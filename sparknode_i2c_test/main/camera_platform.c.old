// camera_platform.c - Homing + 45° indexing control using two hall sensors

#include "camera_platform.h"
#include "esp_log.h"
#include "esp_timer.h"
#include "driver/gpio.h"
#include "drv8830.h"  // motor helpers
#include "syncspark_config.h" // I2C_MASTER_TIMEOUT_MS

// ==== Configuration Tunables (could move to Kconfig later) ====
#define CAM_HOME_SEARCH_SPEED     0x12   // Speed during homing
#define CAM_INDEX_MOVE_SPEED      0x10   // Speed while moving between indices
#define CAM_KICK_ENABLE           1      // Use existing torque kick if >0 (via camera_motor_jog)
#define CAM_INDEX_DWELL_MS        400    // Dwell at each index when auto-stepping
#define CAM_EVENT_DEBOUNCE_US     4000   // Ignore repeat edges within this time
#define CAM_HOME_TIMEOUT_MS       6000   // Fail homing after this time

// Motor direction to treat as forward (true -> inward per previous code assumption)
#define CAM_ROTATE_FORWARD        true

// ==== Internal Types ====
typedef enum {
    CAM_STATE_IDLE=0,
    CAM_STATE_HOMING,
    CAM_STATE_MOVING
} cam_state_t;

typedef enum {
    EVT_HOME=0,
    EVT_RING,
    EVT_GOTO   // command: move to specific target index
} cam_evt_type_t;

typedef struct {
    cam_evt_type_t type;
    uint8_t target; // for EVT_GOTO
} cam_event_t;

// ==== Static Module Data ====
static const char *TAG = "cam_plate";
static i2c_master_dev_handle_t s_cam_motor = NULL;
static QueueHandle_t s_evt_q = NULL;
static cam_state_t s_state = CAM_STATE_IDLE;
static uint8_t s_current_index = 0xFF; // unknown until homed
static uint8_t s_target_index = 0xFF;
static bool s_auto_cycle = false;
static volatile int64_t s_last_home_us = 0;
static volatile int64_t s_last_ring_us = 0;

// Forward decl
static void cam_platform_task(void *arg);
static void start_motor_constant(uint8_t speed);
static void stop_motor_brake_then_coast(void);

uint8_t camera_platform_current_index(void) { return s_current_index; }

// ==== GPIO ISR Handlers ====
static void IRAM_ATTR isr_home(void *arg) {
    int64_t now = esp_timer_get_time();
    if (now - s_last_home_us < CAM_EVENT_DEBOUNCE_US) return;
    s_last_home_us = now;
    cam_event_t evt = {.type = EVT_HOME};
    BaseType_t hpw = pdFALSE;
    if (s_evt_q) xQueueSendFromISR(s_evt_q, &evt, &hpw);
    if (hpw) portYIELD_FROM_ISR();
}
static void IRAM_ATTR isr_ring(void *arg) {
    int64_t now = esp_timer_get_time();
    if (now - s_last_ring_us < CAM_EVENT_DEBOUNCE_US) return;
    s_last_ring_us = now;
    cam_event_t evt = {.type = EVT_RING};
    BaseType_t hpw = pdFALSE;
    if (s_evt_q) xQueueSendFromISR(s_evt_q, &evt, &hpw);
    if (hpw) portYIELD_FROM_ISR();
}

// ==== Motor Helpers ====
static void start_motor_constant(uint8_t speed) {
    // Use direct set (skip jog ramp) for deterministic response
    drive_motor_simple(s_cam_motor, speed, CAM_ROTATE_FORWARD, I2C_MASTER_TIMEOUT_MS);
}
static void stop_motor_brake_then_coast(void) {
    stop_motor_with_mode(s_cam_motor, DRV8830_STOP_BRAKE, I2C_MASTER_TIMEOUT_MS);
    vTaskDelay(pdMS_TO_TICKS(40));
    stop_motor_with_mode(s_cam_motor, DRV8830_STOP_COAST, I2C_MASTER_TIMEOUT_MS);
}

// ==== Public API ====
void camera_platform_init(i2c_master_dev_handle_t cam_motor_handle) {
    s_cam_motor = cam_motor_handle;
    if (!s_evt_q) {
        s_evt_q = xQueueCreate(16, sizeof(cam_event_t));
    }
    // Configure GPIOs
    gpio_config_t cfg = {
        .pin_bit_mask = (1ULL<<CAM_HOME_HALL_GPIO) | (1ULL<<CAM_RING_HALL_GPIO),
        .mode = GPIO_MODE_INPUT,
        .pull_up_en = GPIO_PULLUP_ENABLE,  // adjust if sensors have own pull
        .pull_down_en = GPIO_PULLDOWN_DISABLE,
        .intr_type = GPIO_INTR_DISABLE
    };
    gpio_config(&cfg);
    // Attach interrupts (assuming active-low pulse when magnet present -> falling edge). Adjust if needed.
    // Ensure ISR service installed (ignore if already installed)
    if (gpio_install_isr_service(0) != ESP_OK) {
        // Already installed or error; proceed
    }
    gpio_set_intr_type(CAM_HOME_HALL_GPIO, GPIO_INTR_NEGEDGE);
    gpio_set_intr_type(CAM_RING_HALL_GPIO, GPIO_INTR_NEGEDGE);
    gpio_isr_handler_add(CAM_HOME_HALL_GPIO, isr_home, NULL);
    gpio_isr_handler_add(CAM_RING_HALL_GPIO, isr_ring, NULL);
    gpio_intr_enable(CAM_HOME_HALL_GPIO);
    gpio_intr_enable(CAM_RING_HALL_GPIO);

    // Spawn task
    xTaskCreate(cam_platform_task, "cam_platform", 4096, NULL, 6, NULL);
}

void camera_platform_start(void) {
    // Begin homing sequence
    cam_event_t goto_home = {.type = EVT_GOTO, .target = 0}; // used just to kick task
    s_state = CAM_STATE_HOMING;
    xQueueSend(s_evt_q, &goto_home, 0);
}

esp_err_t camera_platform_goto(uint8_t target_index) {
    if (target_index > 7) return ESP_ERR_INVALID_ARG;
    if (s_current_index == 0xFF) return ESP_ERR_INVALID_STATE; // not homed
    cam_event_t evt = {.type = EVT_GOTO, .target = target_index};
    return xQueueSend(s_evt_q, &evt, pdMS_TO_TICKS(50)) == pdTRUE ? ESP_OK : ESP_ERR_TIMEOUT;
}

// ==== Task State Machine ====
static void cam_platform_task(void *arg) {
    ESP_LOGI(TAG, "Camera platform task started (homing pending)");
    TickType_t home_start_tick = 0;
    uint8_t ring_events_needed = 0; // steps to move

    for (;;) {
        cam_event_t evt;
        if (xQueueReceive(s_evt_q, &evt, pdMS_TO_TICKS(50))) {
            switch (evt.type) {
                case EVT_GOTO:
                    if (s_state == CAM_STATE_HOMING) {
                        // Start homing motion if not already moving
                        if (home_start_tick == 0) {
                            ESP_LOGI(TAG, "Homing: rotating to find index magnet");
                            home_start_tick = xTaskGetTickCount();
                            start_motor_constant(CAM_HOME_SEARCH_SPEED);
                        }
                    } else if (s_state == CAM_STATE_IDLE || s_state == CAM_STATE_MOVING) {
                        if (s_current_index != 0xFF) {
                            s_target_index = evt.target;
                            int diff = (int)s_target_index - (int)s_current_index;
                            if (diff < 0) diff += 8; // forward only wrap
                            ring_events_needed = (uint8_t)diff;
                            if (ring_events_needed == 0) {
                                ESP_LOGI(TAG, "Already at index %d", s_current_index);
                            } else {
                                ESP_LOGI(TAG, "Moving %u steps to index %d", ring_events_needed, s_target_index);
                                start_motor_constant(CAM_INDEX_MOVE_SPEED);
                                s_state = CAM_STATE_MOVING;
                            }
                        }
                    }
                    break;
                case EVT_HOME:
                    if (s_state == CAM_STATE_HOMING) {
                        stop_motor_brake_then_coast();
                        s_current_index = 0; // define home as index 0
                        ESP_LOGI(TAG, "Homing complete (index=0)");
                        s_state = CAM_STATE_IDLE;
                        s_auto_cycle = true; // start auto stepping
                        // Schedule first move to index 1
                        cam_event_t m = {.type = EVT_GOTO, .target = 1};
                        xQueueSend(s_evt_q, &m, 0);
                    }
                    break;
                case EVT_RING:
                    if (s_state == CAM_STATE_MOVING && ring_events_needed > 0) {
                        ring_events_needed--;
                        if (ring_events_needed == 0) {
                            stop_motor_brake_then_coast();
                            // Update index
                            s_current_index = s_target_index;
                            ESP_LOGI(TAG, "Arrived at index %d", s_current_index);
                            s_state = CAM_STATE_IDLE;
                            if (s_auto_cycle) {
                                // queue next
                                uint8_t next = (s_current_index + 1) & 0x7;
                                cam_event_t m = {.type = EVT_GOTO, .target = next};
                                // dwell then move
                                vTaskDelay(pdMS_TO_TICKS(CAM_INDEX_DWELL_MS));
                                xQueueSend(s_evt_q, &m, 0);
                            }
                        }
                    }
                    break;
            }
        }
        // Timeout detection during homing
        if (s_state == CAM_STATE_HOMING && home_start_tick != 0) {
            if ((xTaskGetTickCount() - home_start_tick) * portTICK_PERIOD_MS > CAM_HOME_TIMEOUT_MS) {
                stop_motor_brake_then_coast();
                ESP_LOGE(TAG, "Homing timeout – check hall sensor or magnet");
                s_state = CAM_STATE_IDLE;
            }
        }
    }
}
